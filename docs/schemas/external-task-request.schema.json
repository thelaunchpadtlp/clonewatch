{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://clonewatch.local/schemas/external-task-request.schema.json",
  "title": "ExternalTaskRequest",
  "type": "object",
  "required": [
    "task_id",
    "created_at",
    "from_external_app",
    "requester",
    "title",
    "objective",
    "priority",
    "urgency",
    "status",
    "owner"
  ],
  "properties": {
    "task_id": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "format": "date-time" },
    "from_external_app": { "type": "string", "minLength": 1 },
    "requester": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "objective": { "type": "string", "minLength": 1 },
    "target_paths": {
      "type": "array",
      "items": { "type": "string" }
    },
    "acceptance_criteria": {
      "type": "array",
      "items": { "type": "string" }
    },
    "priority": {
      "type": "string",
      "enum": ["low", "normal", "high"]
    },
    "urgency": {
      "type": "string",
      "enum": ["later", "soon", "now"]
    },
    "status": {
      "type": "string",
      "enum": ["NEW", "CLAIMED", "BLOCKED", "DONE", "REJECTED"]
    },
    "owner": { "type": "string", "minLength": 1 }
  },
  "additionalProperties": false
}
